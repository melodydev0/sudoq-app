rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================
    // USERS COLLECTION
    // Each user can only access their own data
    // ============================================================
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId
        // ELO must be 0-5000 when duelStats or battleStats is present
        && (request.resource.data.duelStats == null || (request.resource.data.duelStats.elo >= 0 && request.resource.data.duelStats.elo <= 5000))
        && (request.resource.data.battleStats == null || (request.resource.data.battleStats.elo >= 0 && request.resource.data.battleStats.elo <= 5000));
      allow delete: if request.auth != null && request.auth.uid == userId;
      
      // Duel match history subcollection
      match /duel_history/{matchId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Achievements subcollection
      match /achievements/{achievementId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // ============================================================
    // LEADERBOARD (Level/XP - root collection)
    // Used for level-based ranking (totalXp, level)
    // ============================================================
    match /leaderboard/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ============================================================
    // DUEL LEADERBOARD (ELO-based)
    // Everyone can read, only owner can write their entry
    // Optimized for 100K+ users with pagination
    // ============================================================
    match /duel_leaderboard/{oderId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == oderId;
      allow update: if request.auth != null && request.auth.uid == oderId
        // Validate ELO bounds
        && request.resource.data.elo >= 0 
        && request.resource.data.elo <= 5000
        // Require timestamp
        && request.resource.data.updatedAt is timestamp;
      allow delete: if request.auth != null && request.auth.uid == oderId;
    }
    
    // ============================================================
    // CACHED LEADERBOARDS (Read-only, updated by Cloud Functions)
    // Sharded by division for performance
    // ============================================================
    match /leaderboard_cache/{document} {
      allow read: if true;
      allow write: if false; // Only Cloud Functions can write
    }
    
    // Division-specific leaderboards (for faster queries)
    match /leaderboard_division/{division}/players/{oderId} {
      allow read: if true;
      allow write: if false; // Only Cloud Functions can write
    }
    
    // ============================================================
    // DUEL BATTLES (Real-time multiplayer)
    // ============================================================
    match /battles/{battleId} {
      // Anyone signed in can read battles they're part of
      allow read: if request.auth != null 
        && (resource.data.player1.oderId == request.auth.uid 
            || resource.data.player2.oderId == request.auth.uid
            || resource.data.status == 'waiting');
      
      // Only signed-in users can create battles
      allow create: if request.auth != null
        && request.resource.data.player1.oderId == request.auth.uid
        && request.resource.data.status in ['waiting', 'countdown', 'playing'];
      
      // Only participants can update their own data
      allow update: if request.auth != null 
        && (resource.data.player1.oderId == request.auth.uid 
            || resource.data.player2.oderId == request.auth.uid)
        // Prevent changing opponent's data directly
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['player1.oderId', 'player2.oderId', 'puzzle', 'solution']));
      
      // No deletion - battles are permanent records
      allow delete: if false;
    }
    
    // ============================================================
    // MATCHMAKING QUEUE
    // For real-time duel matchmaking
    // ============================================================
    match /matchmaking/{oderId} {
      // Anyone can read to find opponents
      allow read: if request.auth != null;
      
      // Only owner can write/delete their entry
      allow create: if request.auth != null && request.auth.uid == oderId
        && request.resource.data.elo >= 0 
        && request.resource.data.elo <= 5000;
      allow update: if request.auth != null && request.auth.uid == oderId;
      allow delete: if request.auth != null && request.auth.uid == oderId;
    }
    
    // ============================================================
    // DUEL SEASONS
    // Seasonal ranking data
    // ============================================================
    match /duel_seasons/{seasonId} {
      allow read: if true;
      allow write: if false; // Only Cloud Functions can write
      
      // Season leaderboard
      match /leaderboard/{oderId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == oderId;
      }
    }
    
    // ============================================================
    // GLOBAL STATS
    // Aggregated statistics (updated by Cloud Functions)
    // ============================================================
    match /global_stats/{document} {
      allow read: if true;
      allow write: if false; // Only Cloud Functions can write
    }
    
    // ============================================================
    // REPORTS (For abuse reporting)
    // ============================================================
    match /reports/{reportId} {
      allow read: if false; // Only admins
      allow create: if request.auth != null
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.createdAt is timestamp;
      allow update, delete: if false;
    }
  }
}
